# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rail_madad"

# Authentication
JWT_SECRET="your-super-secret-jwt-key-rail-madad-2025-secure"
NEXTAUTH_SECRET="your-nextauth-secret-here-rail-madad"
NEXTAUTH_URL="http://localhost:3000"

# Google Gemini AI Configuration
GEMINI_API_KEY="your-gemini-pro-api-key-here"

# File Upload Configuration
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"
STORAGE_BUCKET_URL="your-cloud-storage-bucket-url"

# SMS/Email Notifications (Stubs)
SMS_API_URL="https://api.sms-service.com"
SMS_API_KEY="your-sms-api-key"
SMS_PROVIDER_KEY="your-sms-provider-key"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Application Configuration
APP_NAME="Rail Madad AI"
APP_VERSION="1.0.0"
NODE_ENV="development"
NEXTJS_URL="http://localhost:3000"

# Admin Configuration
ADMIN_EMAIL="admin@railmadad.com"
DEFAULT_ADMIN_PASSWORD="admin123!@#"

# Rate Limiting & Security
RATE_LIMIT_REQUESTS_PER_MINUTE="60"
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Analytics & Monitoring
ANALYTICS_ENABLED="true"
LOG_LEVEL="info"
